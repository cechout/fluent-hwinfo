<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FluentHwInfo.Views.CPUPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FluentHwInfo.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Border
            Padding="20"
            VerticalAlignment="Top"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource ControlElevationBorderBrush}"
            BorderThickness="1"
            CornerRadius="{ThemeResource ControlCornerRadius}">

            <Grid RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource Font_TextBlockOutputDisplay}"
                    Text="Sensor" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Style="{StaticResource Font_TextBlockOutputDisplay}"
                    Text="Aktuell" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Style="{StaticResource Font_TextBlockOutputDisplay}"
                    Text="Minimum" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="3"
                    HorizontalAlignment="Right"
                    Style="{StaticResource Font_TextBlockOutputDisplay}"
                    Text="Maximum" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="4"
                    HorizontalAlignment="Right"
                    Style="{StaticResource Font_TextBlockOutputDisplay}"
                    Text="Durchschnitt" />

                <Border
                    Grid.Row="1"
                    Grid.ColumnSpan="5"
                    Height="1"
                    Margin="0,4,0,4"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Style="{StaticResource Font_ButtonText}"
                    Text="CPU Package Power" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Style="{StaticResource Font_ButtonText}"
                    Text="32.5 W" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Style="{StaticResource Font_ButtonText}"
                    Text="12.1 W" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="3"
                    HorizontalAlignment="Right"
                    Style="{StaticResource Font_ButtonText}"
                    Text="95.0 W" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="4"
                    HorizontalAlignment="Right"
                    Style="{StaticResource Font_ButtonText}"
                    Text="45.3 W" />

                <TextBlock
                    Grid.Row="3"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Style="{StaticResource Font_ButtonText}"
                    Text="GPU Package Power" />
                <TextBlock
                    Grid.Row="3"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Style="{StaticResource Font_ButtonText}"
                    Text="15.0 W" />
                <TextBlock
                    Grid.Row="3"
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Style="{StaticResource Font_ButtonText}"
                    Text="10.5 W" />
                <TextBlock
                    Grid.Row="3"
                    Grid.Column="3"
                    HorizontalAlignment="Right"
                    Style="{StaticResource Font_ButtonText}"
                    Text="115.0 W" />
                <TextBlock
                    Grid.Row="3"
                    Grid.Column="4"
                    HorizontalAlignment="Right"
                    Style="{StaticResource Font_ButtonText}"
                    Text="60.2 W" />
            </Grid>
        </Border>
    </Grid>
</Page>
