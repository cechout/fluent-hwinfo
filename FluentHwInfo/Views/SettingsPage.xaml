<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FluentHwInfo.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:CommunityToolkit.WinUI"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel
            MaxWidth="1000"
            Margin="24"
            HorizontalAlignment="Stretch"
            Spacing="4">

            <TextBlock
                Margin="0,0,0,12"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="Settings" />

            <!--  appearance settings  -->
            <TextBlock
                Margin="1,8,0,6"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="Appearance" />

            <controls:SettingsCard
                Description="Select your preferred color mode for the application"
                Header="App Theme"
                HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                <ComboBox
                    x:Name="ThemeComboBox"
                    Width="150"
                    SelectedIndex="0"
                    SelectionChanged="ThemeComboBox_SelectionChanged">
                    <ComboBoxItem Content="System Default" Tag="Default" />
                    <ComboBoxItem Content="Light" Tag="Light" />
                    <ComboBoxItem Content="Dark" Tag="Dark" />
                </ComboBox>
            </controls:SettingsCard>

            <!--  engine settings  -->
            <TextBlock
                Margin="1,20,0,6"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="Engine" />

            <controls:SettingsCard
                Description="How fast the hardware sensors should be polled"
                Header="Update Interval"
                HeaderIcon="{ui:FontIcon Glyph=&#xE916;}">
                <ComboBox
                    x:Name="IntervalComboBox"
                    Width="150"
                    SelectionChanged="IntervalComboBox_SelectionChanged">
                    <ComboBoxItem Content="100ms" Tag="100" />
                    <ComboBoxItem Content="250ms" Tag="250" />
                    <ComboBoxItem Content="500ms" Tag="500" />
                    <ComboBoxItem Content="1000ms" Tag="1000" />
                    <ComboBoxItem Content="2000ms" Tag="2000" />
                </ComboBox>
            </controls:SettingsCard>

            <!--  widget settings  -->
            <TextBlock
                Margin="1,20,0,6"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="Widget Appearance" />

            <!--  background material  -->
            <controls:SettingsExpander
                Description="Choose the transparency effect and color for the widget window."
                Header="Background Material"
                HeaderIcon="{ui:FontIcon Glyph=&#xEF1F;}"
                IsExpanded="True">

                <ComboBox
                    x:Name="BackdropComboBox"
                    Width="160"
                    SelectionChanged="BackdropComboBox_SelectionChanged">
                    <ComboBoxItem Content="Desktop Acrylic" Tag="Acrylic" />
                    <ComboBoxItem Content="System Mica" Tag="Mica" />
                    <ComboBoxItem Content="Solid (No Blur)" Tag="None" />
                </ComboBox>

                <controls:SettingsExpander.Items>
                    <controls:SettingsCard Description="Adjust the color transparency (Acrylic only)." Header="Tint Opacity">
                        <Slider
                            x:Name="TintSlider"
                            Width="200"
                            Maximum="1"
                            Minimum="0"
                            StepFrequency="0.05"
                            TickFrequency="0.1"
                            ValueChanged="TintSlider_ValueChanged" />
                    </controls:SettingsCard>

                    <controls:SettingsCard Description="Adjust the brightness transparency (Acrylic only)." Header="Luminosity Opacity">
                        <Slider
                            x:Name="LuminositySlider"
                            Width="200"
                            Maximum="1"
                            Minimum="0"
                            StepFrequency="0.05"
                            TickFrequency="0.1"
                            ValueChanged="LuminositySlider_ValueChanged" />
                    </controls:SettingsCard>

                    <controls:SettingsCard Description="Choose between the Windows accent color or a custom color." Header="Background Color Source">
                        <ComboBox
                            x:Name="ColorSourceComboBox"
                            Width="160"
                            SelectionChanged="ColorSourceComboBox_SelectionChanged">
                            <ComboBoxItem Content="Windows Accent" Tag="Accent" />
                            <ComboBoxItem Content="Custom Color" Tag="Custom" />
                        </ComboBox>
                    </controls:SettingsCard>

                    <controls:SettingsCard Description="Select the custom color for the background." Header="Custom Background Color">
                        <controls:ColorPickerButton x:Name="WidgetBackgroundColorPicker" />
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>

            <!--  graph fill color setting  -->
            <controls:SettingsExpander
                Description="Choose the color source for the LiveChart graph."
                Header="Graph Fill Color"
                HeaderIcon="{ui:FontIcon Glyph=&#xE790;}"
                IsExpanded="True">

                <ComboBox
                    x:Name="GraphColorSourceComboBox"
                    Width="160"
                    SelectionChanged="GraphColorSourceComboBox_SelectionChanged">
                    <ComboBoxItem Content="Windows Accent" Tag="Accent" />
                    <ComboBoxItem Content="Custom Color" Tag="Custom" />
                </ComboBox>

                <controls:SettingsExpander.Items>
                    <controls:SettingsCard Description="Select the custom fill color for the graph." Header="Custom Graph Color">
                        <controls:ColorPickerButton x:Name="GraphColorPicker" />
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>

        </StackPanel>
    </ScrollViewer>
</Page>