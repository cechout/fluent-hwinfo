<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="FluentSensors.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:composition="using:Windows.UI.Composition"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fh="using:FluentSensors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tb="using:H.NotifyIcon"
    xmlns:toolkit="using:CommunityToolkit.WinUI"
    xmlns:winex="using:WinUIEx"
    Title="Fluent Sensors"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  custom title bar  -->
        <TitleBar
            Title="Fluent Sensors"
            Grid.Row="0"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="False">

            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/Icon/Icon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <!--  navigation view  -->
        <NavigationView
            x:Name="MainNavigationView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneOpen="False"
            IsSettingsVisible="False"
            OpenPaneLength="150"
            PaneDisplayMode="Left"
            SelectionChanged="MainNavigationView_SelectionChanged">

            <!--  sensor page  -->
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Sensors" Tag="Sensors">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xECAA;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!--  settings page  -->
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="contentFrame" />

        </NavigationView>

        <!--  loading status screen  -->
        <Grid
            x:Name="SplashOverlay"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

            <StackPanel
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Spacing="16">

                <!--  icon  -->
                <Grid HorizontalAlignment="Center">
                    <Border x:Name="ShadowReceiver" />
                    <Image
                        Width="80"
                        Height="80"
                        Source="/Assets/Icon/Icon.png">
                        <toolkit:Effects.Shadow>
                            <toolkit:AttachedDropShadow
                                BlurRadius="11"
                                CastTo="{x:Bind ShadowReceiver}"
                                Opacity="0.22"
                                Offset="0,3,0"
                                Color="Black" />
                        </toolkit:Effects.Shadow>
                    </Image>
                </Grid>

                <ProgressBar
                    x:Name="LoadingProgressBar"
                    Width="200"
                    Margin="0,32,0,0"
                    Maximum="100"
                    Minimum="0"
                    Value="0" />

                <TextBlock
                    x:Name="LoadingStatusText"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    Text="Starting Fluent HwInfo..." />
            </StackPanel>
        </Grid>


        <!--  taskbar icon  -->
        <tb:TaskbarIcon
            x:Name="TrayIcon"
            DoubleClickCommand="{x:Bind ShowMainWindowCommand}"
            IconSource="/Assets/Icon/Icon.ico"
            ToolTipText="Fluent HwInfo"
            Visibility="Visible">

            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Command="{x:Bind ShowMainWindowCommand}" Text="Sensor List" />
                    <MenuFlyoutItem Command="{x:Bind OpenSettingsCommand}" Text="Settings" />
                    <MenuFlyoutItem Command="{x:Bind ExitAppCommand}" Text="Exit App" />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>
    </Grid>
</Window>